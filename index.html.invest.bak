    <div class="sidebar-footer">
      <div class="logout-btn" onclick="logout()">⎋ SIGN OUT</div>
    </div>
  </div>
  <div class="main-area">
    <div class="topbar">
      <div class="topbar-title">Investment Operations Dashboard</div>
      <div class="topbar-badge" id="dir-period-badge">Q2 2026</div>
    </div>
    <div class="content">

      <!-- OVERVIEW TAB -->
      <div id="dir-overview">
        <div class="cards">
          <div class="card"><div class="card-label">TOTAL INVESTED</div><div class="card-value" id="dir-total-invested">—</div><div class="card-sub">Across all managers</div></div>
          <div class="card success"><div class="card-label">TOTAL GAINED</div><div class="card-value" id="dir-total-gained">—</div><div class="card-sub">This period</div></div>
          <div class="card"><div class="card-label">SUBMITTED</div><div class="card-value" id="dir-submitted-count">—</div><div class="card-sub">Managers reported</div></div>
          <div class="card danger"><div class="card-label">MISSING</div><div class="card-value" id="dir-missing-count">—</div><div class="card-sub">Report incomplete</div></div>
        </div>
        <div class="section-header">
          <div class="section-title">MANAGER SUBMISSIONS</div>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>MANAGER</th><th>ASSET CLASS</th><th>INVESTED</th><th>GAINED</th><th>LOST</th><th>STATUS</th></tr></thead>
            <tbody id="dir-overview-tbody"><tr><td colspan="6" style="text-align:center;color:#aab8d0;">Loading...</td></tr></tbody>
          </table>
        </div>

        <!-- DIRECTOR GROWTH CHART -->
        <div class="section-header" style="margin-top:8px;">
          <div class="section-title">PORTFOLIO GROWTH OVER TIME</div>
        </div>
        <div class="chart-card">
          <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
            <button class="chart-tab active" onclick="setDirGroup('manager',this)">By Manager</button>
            <button class="chart-tab" onclick="setDirGroup('asset_class',this)">By Asset Class</button>
          </div>
          <div class="chart-tabs" id="dir-metric-tabs">
            <button class="chart-tab active" onclick="setDirMetric('cumulative_value',this)">Cumulative Value</button>
            <button class="chart-tab" onclick="setDirMetric('net_change',this)">Gain / Loss</button>
            <button class="chart-tab" onclick="setDirMetric('pct_return',this)">% Return</button>
          </div>
          <canvas id="directorGrowthChart" height="300"></canvas>
        </div>
      </div>

      <!-- SUBMISSIONS TAB -->
      <div id="dir-submissions" style="display:none">
        <div class="section-header">
          <div class="section-title">ALL SUBMISSIONS</div>
          <button class="btn-report" id="report-btn" disabled>REPORT LOCKED</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>MANAGER</th><th>ASSET CLASS</th><th>PERIOD</th><th>INVESTED</th><th>GAINED</th><th>LOST</th><th>NET</th><th>SUBMITTED AT</th></tr></thead>
            <tbody id="dir-submissions-tbody"><tr><td colspan="8" style="text-align:center;color:#aab8d0;">Loading...</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- AI TAB -->
