<!-- ══ MANAGER DASHBOARD ══ -->
<div id="manager-dash" class="screen">
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-brand">CIPHER</div>
      <div class="sidebar-role">MANAGER PORTAL</div>
    </div>
    <div class="nav-section-label">MY PORTFOLIO</div>
    <div class="nav-item active" onclick="mgrTab(this,'mgr-submit')"><span class="nav-dot"></span>Submit Data</div>
    <div class="nav-item" onclick="mgrTab(this,'mgr-history')"><span class="nav-dot"></span>My History</div>
    <div class="sidebar-footer">
      <div class="logout-btn" onclick="logout()">⎋ SIGN OUT</div>
    </div>
  </div>
  <div class="main-area">
    <div class="topbar">
      <div class="topbar-title">Manager Portfolio Submission</div>
      <div class="topbar-badge">Q2 2026</div>
    </div>
    <div class="content">

      <!-- SUBMIT TAB -->
      <div id="mgr-submit">
        <div class="submit-card">
          <h2>SUBMIT PORTFOLIO DATA</h2>
          <p>Enter your portfolio figures for the current reporting period. All fields are required.</p>
          <div class="input-row">
            <div class="input-group">
              <label>REPORTING PERIOD</label>
              <select id="m-period">
                <option>Q2 2026</option><option>Q1 2026</option>
                <option>Q4 2025</option><option>Q3 2025</option><option>Q2 2025</option><option>Q1 2025</option>
                <option>Q4 2024</option><option>Q3 2024</option><option>Q2 2024</option><option>Q1 2024</option>
              </select>
            </div>
            <div class="input-group"><label>TOTAL INVESTED ($)</label><input type="number" placeholder="0.00" id="m-invested"/></div>
          </div>
          <div class="input-row">
            <div class="input-group"><label>TOTAL GAINED ($)</label><input type="number" placeholder="0.00" id="m-gained"/></div>
            <div class="input-group"><label>TOTAL LOST ($)</label><input type="number" placeholder="0.00" id="m-lost"/></div>
          </div>
          <div class="input-group" style="margin-bottom:24px">
            <label>NOTES (OPTIONAL)</label>
            <textarea id="m-notes" placeholder="Any additional context for this period..."></textarea>
          </div>
          <button class="btn-primary" style="max-width:100%" onclick="submitData()">SUBMIT PORTFOLIO DATA</button>
          <div class="submit-success" id="submit-success">✓ Submission received. Your data has been recorded.</div>
        </div>
      </div>

      <!-- HISTORY TAB -->
      <div id="mgr-history" style="display:none">
        <div class="section-header">
          <div class="section-title">MY SUBMISSION HISTORY</div>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>PERIOD</th><th>INVESTED</th><th>GAINED</th><th>LOST</th><th>NET</th><th>SUBMITTED</th></tr></thead>
            <tbody id="mgr-history-tbody"><tr><td colspan="6" style="text-align:center;color:#aab8d0;">Loading...</td></tr></tbody>
          </table>
        </div>

        <!-- MANAGER GROWTH CHART -->
        <div class="section-header" style="margin-top:8px;">
          <div class="section-title">MY GROWTH OVER TIME</div>
        </div>
        <div class="chart-card">
          <div class="chart-tabs">
            <button class="chart-tab active" onclick="setMgrMetric('cumulative_value',this)">Cumulative Value</button>
            <button class="chart-tab" onclick="setMgrMetric('net_change',this)">Gain / Loss</button>
            <button class="chart-tab" onclick="setMgrMetric('pct_return',this)">% Return</button>
          </div>
          <canvas id="managerGrowthChart" height="280"></canvas>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  // ══ SPLASH ══
  window.addEventListener('load', () => {
    show('login');
    const overlay = document.getElementById('logo-overlay');
    const splash  = document.getElementById('splash');
    setTimeout(() => overlay.classList.add('visible'), 300);
    setTimeout(() => overlay.classList.add('zoom'), 1800);
    setTimeout(() => splash.classList.add('slide-down'), 3400);
    setTimeout(() => splash.remove(), 5400);
  });

  // ══ CORE ══
  function show(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const el = document.getElementById(id);
    if (el) el.classList.add('active');
  }

  const API = "http://127.0.0.1:8000";
  let currentUser = null;
  let pendingUser = null;
  let generatedCode = null;

  // ══ LOGOUT ══
  function logout() {
    currentUser = null;
    pendingUser = null;
    generatedCode = null;
    document.querySelectorAll('input').forEach(el => el.value = '');
    document.querySelectorAll('textarea').forEach(el => el.value = '');
    document.querySelectorAll('.login-error').forEach(el => el.style.display = 'none');
    show('login');
    showPortalSelect();
  }

  // ══ PORTAL NAV ══
  function showPortal(type) {
    document.getElementById('portal-select').style.display = 'none';
    document.getElementById('investment-login').style.display = type === 'investment' ? 'flex' : 'none';
    document.getElementById('manager-login').style.display   = type === 'manager'    ? 'flex' : 'none';
    document.querySelector('.login-right').scrollTop = 0;
  }

  function showPortalSelect() {
    document.getElementById('portal-select').style.display = 'flex';
    document.getElementById('portal-select').style.flexDirection = 'column';
    document.getElementById('portal-select').style.alignItems = 'center';
    ['investment-login','investment-signup','manager-login','manager-signup'].forEach(id => {
      document.getElementById(id).style.display = 'none';
    });
    document.querySelector('.login-right').scrollTop = 0;
  }

  function toggleSignup(type) {
    document.getElementById(type + '-login').style.display = 'none';
    document.getElementById(type + '-signup').style.display = 'flex';
    document.querySelector('.login-right').scrollTop = 0;
  }

  function toggleLogin(type) {
    document.getElementById(type + '-signup').style.display = 'none';
    document.getElementById(type + '-login').style.display = 'flex';
    document.querySelector('.login-right').scrollTop = 0;
  }

  // ══ 2FA ══
  function generate6DigitCode() { return String(Math.floor(100000 + Math.random() * 900000)); }

  function sendVerificationCode(user) {
    generatedCode = generate6DigitCode();
    console.log('%c[CIPHER 2FA] Your verification code: ' + generatedCode,
      'background:#0A2472;color:#A8D4F5;font-size:16px;padding:6px 12px;border-radius:4px;');
    console.log('(In production this will be sent via SMS to the registered phone number)');
  }

  function verifyTwoFA() {
    const entered = document.getElementById('twofa-code').value.trim();
    const errorEl = document.getElementById('twofa-error');
    if (!entered || entered.length !== 6) {
      errorEl.textContent = "Please enter the 6-digit code.";
      errorEl.style.display = 'block';
      return;
    }
    if (entered !== generatedCode) {
      errorEl.textContent = "Incorrect code. Please try again.";
      errorEl.style.display = 'block';
      document.getElementById('twofa-code').value = '';
      return;
    }
    errorEl.style.display = 'none';
    currentUser = pendingUser;
    pendingUser = null;
    generatedCode = null;
    enterDashboard();
  }

  function resendCode() {
    if (!pendingUser) return;
    document.getElementById('twofa-code').value = '';
    document.getElementById('twofa-error').style.display = 'none';
    sendVerificationCode(pendingUser);
    document.getElementById('twofa-hint').textContent = 'New code generated — check your browser console (F12).';
  }

  // ══ SIGNUP ══
  async function doSignup(role) {
    const prefix = role === 'investment_manager' ? 'invsign' : 'mgrsign';
    const name             = document.getElementById(prefix + '-name').value.trim();
    const email            = document.getElementById(prefix + '-email').value.trim();
    const email2           = document.getElementById(prefix + '-email2').value.trim();
    const password         = document.getElementById(prefix + '-password').value;
    const password2        = document.getElementById(prefix + '-password2').value;
    const institution_name = document.getElementById(prefix + '-institution').value.trim();
    const ein              = document.getElementById(prefix + '-ein').value.trim();
    const domain           = document.getElementById(prefix + '-domain').value.trim().toLowerCase();
    const errorEl          = document.getElementById(prefix + '-error');

    let asset_class = null, job_title = null, phone_number = null, institution_location = null;

    if (role === 'manager') {
      asset_class = document.getElementById('mgrsign-asset').value;
    } else {
      job_title            = document.getElementById('invsign-title').value.trim();
      phone_number         = document.getElementById('invsign-phone').value.trim();
      institution_location = document.getElementById('invsign-location').value.trim();
    }

    // Validation
    if (!name || !email || !email2 || !password || !password2 || !institution_name || !ein || !domain) {
      errorEl.textContent = "Please fill in all required fields."; errorEl.style.display = 'block'; return;
    }
    if (role === 'manager' && !asset_class) {
      errorEl.textContent = "Please select an asset class."; errorEl.style.display = 'block'; return;
    }
    if (role === 'investment_manager' && (!job_title || !phone_number || !institution_location)) {
      errorEl.textContent = "Please fill in all required fields."; errorEl.style.display = 'block'; return;
    }
    if (email !== email2) {
      errorEl.textContent = "Email addresses do not match."; errorEl.style.display = 'block'; return;
    }
    if (!email.toLowerCase().endsWith('@' + domain)) {
      errorEl.textContent = "Your email must match the work domain you entered."; errorEl.style.display = 'block'; return;
    }
    if (password !== password2) {
      errorEl.textContent = "Passwords do not match."; errorEl.style.display = 'block'; return;
    }
    if (password.length < 8) {
      errorEl.textContent = "Password must be at least 8 characters."; errorEl.style.display = 'block'; return;
    }

    try {
      const res = await fetch(`${API}/auth/signup`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ name, email, password, role, asset_class, institution_name, institution_location, job_title, phone_number })
      });
      const data = await res.json();
      if (!res.ok) { errorEl.textContent = data.detail || "Signup failed."; errorEl.style.display = 'block'; return; }
      errorEl.style.display = 'none';
      pendingUser = { user_id: data.user_id, name: data.name, role: data.role, asset_class: data.asset_class };
      sendVerificationCode(pendingUser);
      document.getElementById('twofa-hint').textContent = 'Account created! Check your browser console (F12) for your verification code.';
      document.getElementById('twofa-code').value = '';
      document.getElementById('twofa-error').style.display = 'none';
      show('twofa');
    } catch (e) {
      errorEl.textContent = "Could not connect to server."; errorEl.style.display = 'block';
    }
  }

  // ══ LOGIN ══
  async function doLogin(role) {
    const prefix  = role === 'investment_manager' ? 'inv' : 'mgr';
    const email    = document.getElementById(prefix + '-email').value;
    const password = document.getElementById(prefix + '-password').value;
    const errorEl  = document.getElementById(prefix + '-error');

    if (!email || !password) { errorEl.textContent = "Please fill in all fields."; errorEl.style.display = 'block'; return; }

    try {
      const res = await fetch(`${API}/auth/login`, {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ email, password, role })
      });
      const data = await res.json();
      if (!res.ok) { errorEl.textContent = data.detail || "Invalid credentials."; errorEl.style.display = 'block'; return; }
      errorEl.style.display = 'none';
      pendingUser = data;
      sendVerificationCode(data);
      document.getElementById('twofa-hint').textContent = 'Check your browser console (F12) for your verification code (testing mode).';
      document.getElementById('twofa-code').value = '';
      document.getElementById('twofa-error').style.display = 'none';
      show('twofa');
    } catch (e) {
      errorEl.textContent = "Could not connect to server."; errorEl.style.display = 'block';
    }
  }

  function enterDashboard() {
    if (currentUser.role === 'investment_manager') {
      show('director-dash');
      loadDirectorData();
    } else {
      show('manager-dash');
      loadManagerHistory();
    }
  }

  // ══ TABS ══
  function dirTab(el, tabId) {
    document.querySelectorAll('#director-dash .nav-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
    ['dir-overview','dir-submissions','dir-analytics','dir-exposure','dir-liquidity','dir-private','dir-ai','dir-report'].forEach(id => {
      const t = document.getElementById(id);
      if (t) t.style.display = id === tabId ? 'block' : 'none';
    });
  }

  function mgrTab(el, tabId) {
    document.querySelectorAll('#manager-dash .nav-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
    ['mgr-submit','mgr-history'].forEach(id => {
      const t = document.getElementById(id);
      if (t) t.style.display = id === tabId ? 'block' : 'none';
    });
    if (tabId === 'mgr-history') {
      loadManagerHistory().then(() => {
        fetchFullHistory().then(() => renderManagerChart());
      });
    }
  }

  // ══ SUBMIT DATA ══
  async function submitData() {
    const invested = document.getElementById('m-invested').value;
    const gained   = document.getElementById('m-gained').value;
    const lost     = document.getElementById('m-lost').value;
    const period   = document.getElementById('m-period').value;
    const notes    = document.getElementById('m-notes').value;
    if (!invested || !gained || !lost || !currentUser) return;

    try {
      const res = await fetch(`${API}/submissions/submit`, {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          manager_id: currentUser.user_id,
          total_invested: parseFloat(invested),
          total_gained: parseFloat(gained),
          total_lost: parseFloat(lost),
          notes: notes,
          period: period
        })
      });
      if (res.ok) {
        const successEl = document.getElementById('submit-success');
        successEl.textContent = `✓ Submission received. Your data has been recorded for ${period}.`;
        successEl.style.display = 'block';
        loadManagerHistory();
      }
    } catch (e) { console.error("Submission failed", e); }
  }

  // ══ LOAD MANAGER HISTORY ══
  async function loadManagerHistory() {
    if (!currentUser) return;
    try {
      const res  = await fetch(`${API}/submissions/manager/${currentUser.user_id}`);
      const data = await res.json();
      const tbody = document.getElementById('mgr-history-tbody');
      if (!tbody) return;
      if (!data.submissions.length) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#aab8d0;">No submissions yet.</td></tr>';
        return;
      }
      tbody.innerHTML = data.submissions.map(s => `
        <tr>
          <td>${s.period}</td>
          <td>$${Number(s.total_invested).toLocaleString()}</td>
          <td>$${Number(s.total_gained).toLocaleString()}</td>
          <td>$${Number(s.total_lost).toLocaleString()}</td>
          <td style="color:#2e7d32">+$${(s.total_gained - s.total_lost).toLocaleString()}</td>
          <td><span class="badge submitted">SUBMITTED</span></td>
        </tr>
      `).join('');
    } catch (e) { console.error("Could not load history", e); }
  }

  // ══ LOAD DIRECTOR DATA ══
  async function loadDirectorData() {
    try {
      const res  = await fetch(`${API}/submissions/Q2 2026`);
      const data = await res.json();

      const totalInvested = data.managers.reduce((s, m) => s + (m.total_invested || 0), 0);
      const totalGained   = data.managers.reduce((s, m) => s + (m.total_gained   || 0), 0);

      document.getElementById('dir-total-invested').textContent  = `$${(totalInvested/1000000).toFixed(1)}M`;
      document.getElementById('dir-total-gained').textContent    = `$${(totalGained/1000000).toFixed(1)}M`;
      document.getElementById('dir-submitted-count').textContent = `${data.submitted} / ${data.total_managers}`;
      document.getElementById('dir-missing-count').textContent   = data.missing;

      const tbody = document.getElementById('dir-overview-tbody');
      if (tbody) {
        tbody.innerHTML = data.managers.map(m => `
          <tr>
            <td>${m.name}</td>
            <td>${m.asset_class || '—'}</td>
            <td>${m.submitted ? '$' + Number(m.total_invested).toLocaleString() : '—'}</td>
            <td>${m.submitted ? '$' + Number(m.total_gained).toLocaleString()   : '—'}</td>
            <td>${m.submitted ? '$' + Number(m.total_lost).toLocaleString()     : '—'}</td>
            <td><span class="badge ${m.submitted ? 'submitted' : 'missing'}">${m.submitted ? 'SUBMITTED' : 'MISSING'}</span></td>
          </tr>
        `).join('');
      }

      const reportBtn = document.getElementById('report-btn');
      if (reportBtn) {
        reportBtn.disabled    = !data.complete;
        reportBtn.textContent = data.complete ? 'GENERATE REPORT' : `REPORT LOCKED — ${data.missing} MISSING`;
      }

      await fetchFullHistory();
      renderDirectorChart();
    } catch (e) { console.error("Could not load director data", e); }
  }

  // ══ CHARTS ══
  const NAVY    = "#0A2472";
  const SKY     = "#4A90D9";
  const SOFT    = "#A8D4F5";
  const PALETTE = [NAVY, SKY, "#7C3AED", "#16A34A", "#DC2626", "#D97706", "#0891B2", SOFT];
  const METRIC_LABELS = {
    cumulative_value: "Cumulative Value ($)",
    net_change:       "Gain / Loss ($)",
    pct_return:       "% Return"
  };

  let fullHistory    = [];
  let mgrMetric      = 'cumulative_value';
  let dirMetric      = 'cumulative_value';
  let dirGroup       = 'manager';
  let mgrChartInst   = null;
  let dirChartInst   = null;

  async function fetchFullHistory() {
    try {
      const res  = await fetch(`${API}/submissions/history/all`);
      const data = await res.json();
      fullHistory = data.history || [];
    } catch (e) { fullHistory = []; }
  }

  function getPeriods(rows) { return [...new Set(rows.map(r => r.period))]; }
  function avg(arr) { return arr.length ? arr.reduce((a,b)=>a+b,0)/arr.length : 0; }

  function setMgrMetric(metric, btn) {
    mgrMetric = metric;
    document.querySelectorAll('#mgr-history .chart-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderManagerChart();
  }

  function setDirMetric(metric, btn) {
    dirMetric = metric;
    document.querySelectorAll('#dir-metric-tabs .chart-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderDirectorChart();
  }

  function setDirGroup(group, btn) {
    dirGroup = group;
    btn.closest('div').querySelectorAll('.chart-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderDirectorChart();
  }

  function renderManagerChart() {
    const canvas = document.getElementById('managerGrowthChart');
    if (!canvas || !currentUser) return;
    const myRows      = fullHistory.filter(h => h.manager_id === currentUser.user_id);
    const myClass     = myRows[0]?.asset_class;
    const peerRows    = fullHistory.filter(h => h.asset_class === myClass);
    const periods     = getPeriods(peerRows.length ? peerRows : myRows);
    const myData      = periods.map(p => myRows.find(r => r.period === p)?.[mgrMetric] ?? null);
    const benchData   = periods.map(p => {
      const peers = peerRows.filter(r => r.period === p && r.manager_id !== currentUser.user_id);
      return peers.length ? avg(peers.map(r => r[mgrMetric])) : null;
    });
    if (mgrChartInst) mgrChartInst.destroy();
    mgrChartInst = new Chart(canvas, {
      type: 'line',
      data: { labels: periods, datasets: [
        { label: 'You', data: myData, borderColor: NAVY, backgroundColor: NAVY, tension: 0.3, spanGaps: true, pointRadius: 5 },
        { label: (myClass || 'Peer') + ' Average', data: benchData, borderColor: SKY, backgroundColor: SKY, borderDash: [6,4], tension: 0.3, spanGaps: true, pointRadius: 5 }
      ]},
      options: { responsive: true, plugins: { legend: { position: 'bottom' }}, scales: { y: { title: { display: true, text: METRIC_LABELS[mgrMetric] }}}}
    });
  }

  function renderDirectorChart() {
    const canvas = document.getElementById('directorGrowthChart');
    if (!canvas) return;
    const periods = getPeriods(fullHistory);
    let datasets = [];
    if (dirGroup === 'manager') {
      const ids = [...new Set(fullHistory.map(h => h.manager_id))];
      datasets = ids.map((id, i) => {
        const rows = fullHistory.filter(h => h.manager_id === id);
        return { label: rows[0]?.manager_name || `Manager ${id}`, data: periods.map(p => rows.find(r => r.period === p)?.[dirMetric] ?? null), borderColor: PALETTE[i % PALETTE.length], backgroundColor: PALETTE[i % PALETTE.length], tension: 0.3, spanGaps: true, pointRadius: 5 };
      });
    } else {
      const classes = [...new Set(fullHistory.map(h => h.asset_class).filter(Boolean))];
      datasets = classes.map((ac, i) => {
        const rows = fullHistory.filter(h => h.asset_class === ac);
        return { label: ac, data: periods.map(p => { const atP = rows.filter(r => r.period === p); return atP.length ? avg(atP.map(r => r[dirMetric])) : null; }), borderColor: PALETTE[i % PALETTE.length], backgroundColor: PALETTE[i % PALETTE.length], tension: 0.3, spanGaps: true, pointRadius: 5 };
      });
    }
    if (dirChartInst) dirChartInst.destroy();
    dirChartInst = new Chart(canvas, {
      type: 'line',
      data: { labels: periods, datasets },
      options: { responsive: true, plugins: { legend: { position: 'bottom' }}, scales: { y: { title: { display: true, text: METRIC_LABELS[dirMetric] }}}}
    });
  }

  // ══ ANALYTICS CHARTS ══
  const PALETTE8 = ["#0A2472","#4A90D9","#A8D4F5","#7C3AED","#16A34A","#DC2626","#D97706","#0891B2"];

  function initAnalyticsCharts() {
    // Performance by asset class
    const perfCtx = document.getElementById('chart-perf-class');
    if (perfCtx && !perfCtx.dataset.init) {
      perfCtx.dataset.init = '1';
      new Chart(perfCtx, { type:'bar', data:{ labels:['Public Equity','Private Equity','Fixed Income','Real Assets','Operations'], datasets:[{ label:'Return %', data:[11.2,9.8,4.1,6.7,-1.2], backgroundColor:["#2e7d32","#2e7d32","#2e7d32","#2e7d32","#e74c3c"] }]}, options:{ responsive:true, plugins:{legend:{display:false}}, scales:{y:{title:{display:true,text:'Return (%)'}}} }});
    }
    // Portfolio value over time
    const pvCtx = document.getElementById('chart-port-value');
    if (pvCtx && !pvCtx.dataset.init) {
      pvCtx.dataset.init = '1';
      new Chart(pvCtx, { type:'line', data:{ labels:['Q1 2024','Q2 2024','Q3 2024','Q4 2024','Q1 2025','Q2 2025','Q3 2025','Q4 2025','Q1 2026','Q2 2026'], datasets:[{ label:'Portfolio Value ($M)', data:[98.2,101.4,104.8,107.1,110.3,113.9,116.2,119.7,122.1,124.6], borderColor:'#0A2472', backgroundColor:'rgba(10,36,114,0.08)', tension:0.3, fill:true }]}, options:{ responsive:true, plugins:{legend:{display:false}}, scales:{y:{title:{display:true,text:'Value ($M)'}}} }});
    }
    // Sector exposure
    const secCtx = document.getElementById('chart-sector');
    if (secCtx && !secCtx.dataset.init) {
      secCtx.dataset.init = '1';
      new Chart(secCtx, { type:'doughnut', data:{ labels:['Healthcare','Technology','Real Estate','Infrastructure','Other'], datasets:[{ data:[35,20,15,10,20], backgroundColor:PALETTE8 }]}, options:{ responsive:true, plugins:{legend:{position:'bottom'}} }});
    }
    // Geography exposure
    const geoCtx = document.getElementById('chart-geo');
    if (geoCtx && !geoCtx.dataset.init) {
      geoCtx.dataset.init = '1';
      new Chart(geoCtx, { type:'doughnut', data:{ labels:['North America','Europe','Asia Pacific','Latin America','Other'], datasets:[{ data:[62,18,12,5,3], backgroundColor:PALETTE8 }]}, options:{ responsive:true, plugins:{legend:{position:'bottom'}} }});
    }
    // Asset type
    const typeCtx = document.getElementById('chart-type');
    if (typeCtx && !typeCtx.dataset.init) {
      typeCtx.dataset.init = '1';
      new Chart(typeCtx, { type:'doughnut', data:{ labels:['Public Equity','Private Equity','Fixed Income','Real Assets','Cash'], datasets:[{ data:[34,25,20,15,6], backgroundColor:PALETTE8 }]}, options:{ responsive:true, plugins:{legend:{position:'bottom'}} }});
    }
    // Liquidity profile
    const liqCtx = document.getElementById('chart-liquidity');
    if (liqCtx && !liqCtx.dataset.init) {
      liqCtx.dataset.init = '1';
      new Chart(liqCtx, { type:'bar', data:{ labels:['Immediate','30 Days','90 Days','1 Year','1-3 Years','>3 Years'], datasets:[{ label:'Value ($M)', data:[18.4,12.8,8.6,6.4,24.2,50.6], backgroundColor:['#2e7d32','#4A90D9','#A8D4F5','#D97706','#e74c3c','#7C3AED'] }]}, options:{ responsive:true, plugins:{legend:{display:false}}, scales:{y:{title:{display:true,text:'Value ($M)'}}} }});
    }
    // Currency exposure
    const curCtx = document.getElementById('chart-currency');
    if (curCtx && !curCtx.dataset.init) {
      curCtx.dataset.init = '1';
      new Chart(curCtx, { type:'doughnut', data:{ labels:['USD','EUR','JPY','GBP','Other'], datasets:[{ data:[68,14,8,6,4], backgroundColor:PALETTE8 }]}, options:{ responsive:true, plugins:{legend:{position:'bottom'}} }});
    }
    // J-Curve
    const jCtx = document.getElementById('chart-jcurve');
    if (jCtx && !jCtx.dataset.init) {
      jCtx.dataset.init = '1';
      new Chart(jCtx, { type:'line', data:{ labels:['Year 0','Year 1','Year 2','Year 3','Year 4','Year 5','Year 6','Year 7'], datasets:[{ label:'Net Cash Flow ($M)', data:[-4.2,-6.8,-5.1,-2.3,1.8,6.4,11.2,16.8], borderColor:'#0A2472', backgroundColor:'rgba(10,36,114,0.08)', tension:0.4, fill:true, pointBackgroundColor: d => d.raw < 0 ? '#e74c3c' : '#2e7d32' }]}, options:{ responsive:true, plugins:{legend:{display:false}}, scales:{y:{title:{display:true,text:'Net Cash Flow ($M)'}}} }});
    }
    // Cash flow forecast
    const cfCtx = document.getElementById('chart-cashflow');
    if (cfCtx && !cfCtx.dataset.init) {
      cfCtx.dataset.init = '1';
      new Chart(cfCtx, { type:'bar', data:{ labels:['Q3 2026','Q4 2026','Q1 2027','Q2 2027','Q3 2027','Q4 2027'], datasets:[{ label:'Contributions', data:[-2.1,-1.8,-3.2,-1.4,-0.8,-1.2], backgroundColor:'#e74c3c' },{ label:'Distributions', data:[1.4,2.8,1.2,4.6,3.1,5.8], backgroundColor:'#2e7d32' }]}, options:{ responsive:true, plugins:{legend:{position:'bottom'}}, scales:{y:{title:{display:true,text:'Cash Flow ($M)'}}} }});
    }
  }

  // Patch dirTab to init charts when analytics tabs are opened
  const _origDirTab = dirTab;
  dirTab = function(el, tabId) {
    _origDirTab(el, tabId);
    if (['dir-analytics','dir-exposure','dir-liquidity','dir-private'].includes(tabId)) {
      setTimeout(initAnalyticsCharts, 50);
    }
  };
</script>
</body>
</html>
