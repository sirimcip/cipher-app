<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CIPHER</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --navy: #0A2472;
      --navy-dark: #071a54;
      --navy-light: #1a3a8a;
      --sky: #4A90D9;
      --soft: #A8D4F5;
      --white: #ffffff;
      --bg: #f0f4fa;
      --red: #e74c3c;
      --green: #2e7d32;
    }

    body { font-family: 'Georgia', serif; background: var(--navy); overflow: hidden; }

    .screen { position: fixed; inset: 0; display: none; }
    .screen.active { display: flex; }

    /* ── SPLASH ── */
    #splash {
      display: flex; align-items: center; justify-content: center;
      position: fixed; top: -20%; left: -20%; width: 140%; height: 140%;
      z-index: 999; background: var(--navy);
      transition: transform 1.8s cubic-bezier(0.65,0,0.35,1);
      will-change: transform; backface-visibility: hidden;
      transform: translateY(0) translateZ(0); isolation: isolate;
    }
    #splash.slide-down { transform: translateY(700%) translateZ(0); pointer-events: none; }
    #logo-overlay {
      text-align: center; opacity: 0;
      transition: opacity 0.8s ease, transform 1.6s cubic-bezier(0.6,0,0.2,1);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      transform: scale(1); transform-origin: center center;
    }
    #logo-overlay.visible { opacity: 1; transform: scale(1); }
    #logo-overlay.zoom    { opacity: 1; transform: scale(40); }
    #logo-overlay.zoom .splash-name { opacity: 0; transition: opacity 0.4s ease; }
    .splash-name { font-size: 64px; font-weight: bold; letter-spacing: 16px; color: var(--white); transition: opacity 0.5s ease; }
    .splash-hex  { width: 80px; height: 92px; margin-bottom: 20px; display: block; }

    /* ── LOGIN ── */
    #login { flex-direction: row; height: 100vh; }
    #twofa { flex-direction: row; height: 100vh; }

    .login-left {
      width: 50%; background: var(--navy);
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24px;
    }
    .login-left .brand-name { font-size: 48px; font-weight: bold; letter-spacing: 12px; color: var(--white); }
    .login-left .brand-tag  { font-size: 9px; letter-spacing: 2.5px; color: var(--soft); font-family: 'Courier New', monospace; text-align: center; padding: 0 40px; line-height: 1.8; }
    .login-divider { width: 60px; height: 1px; background: var(--sky); }
    .login-right {
      width: 50%; background: var(--white);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 40px 60px; overflow-y: auto; height: 100vh;
    }
    .login-right > div { width: 100%; display: flex; flex-direction: column; align-items: center; padding: 40px 60px; min-height: min-content; }
    #portal-select { margin: auto 0; }
    .login-title  { font-size: 26px; font-weight: bold; color: var(--navy); margin-bottom: 8px; }
    .login-sub    { font-size: 12px; color: var(--sky); font-family: 'Courier New', monospace; letter-spacing: 1px; margin-bottom: 40px; }

    .form-group { width: 100%; max-width: 360px; margin-bottom: 20px; }
    .form-group label { display: block; font-size: 10px; letter-spacing: 2px; color: var(--navy); font-family: 'Courier New', monospace; margin-bottom: 8px; }
    .form-group input, .form-group select {
      width: 100%; padding: 14px 16px; border: 1.5px solid #dde6f5; border-radius: 8px;
      font-size: 14px; color: var(--navy); font-family: 'Georgia', serif; outline: none; transition: border 0.2s;
    }
    .form-group input:focus, .form-group select:focus { border-color: var(--sky); }
    .form-hint { font-size: 10px; color: #aab8d0; font-family: 'Courier New', monospace; margin-top: 4px; }

    .btn-primary {
      width: 100%; max-width: 360px; padding: 15px; background: var(--navy); color: var(--white);
      border: none; border-radius: 8px; font-size: 13px; letter-spacing: 3px;
      font-family: 'Courier New', monospace; cursor: pointer; transition: background 0.2s; margin-top: 8px;
    }
    .btn-primary:hover { background: var(--navy-light); }
    .login-error { color: var(--red); font-size: 12px; font-family: 'Courier New', monospace; margin-top: 12px; display: none; }

    .portal-card {
      display: flex; align-items: center; gap: 16px; padding: 20px;
      border: 1.5px solid #dde6f5; border-radius: 12px; cursor: pointer; transition: all 0.2s;
    }
    .portal-card:hover { border-color: var(--sky); background: #f5f9ff; transform: translateX(4px); }
    .portal-icon  { font-size: 24px; color: var(--navy); flex-shrink: 0; }
    .portal-title { font-size: 14px; font-weight: bold; color: var(--navy); margin-bottom: 4px; }
    .portal-desc  { font-size: 11px; color: #aab8d0; font-family: 'Courier New', monospace; }
    .portal-arrow { margin-left: auto; color: var(--sky); font-size: 18px; flex-shrink: 0; }
    .back-btn { font-size: 11px; color: var(--sky); font-family: 'Courier New', monospace; letter-spacing: 1px; cursor: pointer; }
    .back-btn:hover { color: var(--navy); }

    /* ── DASHBOARD SHARED ── */
    #director-dash, #manager-dash { flex-direction: row; }
    .sidebar { width: 240px; background: var(--navy); display: flex; flex-direction: column; padding: 0; flex-shrink: 0; }
    .sidebar-header { padding: 28px 24px; border-bottom: 1px solid var(--navy-light); }
    .sidebar-brand  { font-size: 20px; font-weight: bold; letter-spacing: 5px; color: var(--white); }
    .sidebar-role   { font-size: 8px; color: var(--sky); letter-spacing: 2px; font-family: 'Courier New', monospace; margin-top: 4px; }
    .nav-section-label { padding: 20px 24px 6px; font-size: 8px; letter-spacing: 2.5px; color: var(--sky); font-family: 'Courier New', monospace; }
    .nav-item { padding: 12px 24px; color: var(--soft); font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: background 0.2s; }
    .nav-item:hover, .nav-item.active { background: var(--navy-light); color: var(--white); }
    .nav-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sky); flex-shrink: 0; }
    .sidebar-footer { margin-top: auto; padding: 20px 24px; border-top: 1px solid var(--navy-light); }
    .logout-btn { font-size: 11px; color: var(--soft); letter-spacing: 2px; font-family: 'Courier New', monospace; cursor: pointer; transition: color 0.2s; }
    .logout-btn:hover { color: var(--white); }
    .main-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .topbar { background: var(--white); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #dde6f5; flex-shrink: 0; }
    .topbar-title { font-size: 17px; font-weight: bold; color: var(--navy); }
    .topbar-badge { font-size: 11px; color: var(--sky); background: #eef5ff; padding: 6px 16px; border-radius: 20px; font-family: 'Courier New', monospace; letter-spacing: 1px; }
    .content { flex: 1; padding: 32px; overflow-y: auto; background: var(--bg); }

    /* ── CARDS ── */
    .cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .card { background: var(--white); border-radius: 12px; padding: 24px; border-top: 3px solid var(--sky); }
    .card.danger  { border-top-color: var(--red); }
    .card.success { border-top-color: var(--green); }
    .card-label { font-size: 9px; letter-spacing: 2.5px; color: var(--sky); font-family: 'Courier New', monospace; margin-bottom: 10px; }
    .card-value { font-size: 28px; font-weight: bold; color: var(--navy); }
    .card.danger .card-value  { color: var(--red); }
    .card.success .card-value { color: var(--green); }
    .card-sub { font-size: 11px; color: #aab8d0; margin-top: 6px; }

    /* ── TABLES ── */
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title  { font-size: 13px; font-weight: bold; color: var(--navy); letter-spacing: 1.5px; font-family: 'Courier New', monospace; }
    .table-wrap { background: var(--white); border-radius: 12px; overflow: hidden; margin-bottom: 32px; }
    table { width: 100%; border-collapse: collapse; }
    thead { background: var(--navy); }
    thead th { padding: 14px 20px; text-align: left; font-size: 9px; letter-spacing: 2px; color: var(--soft); font-family: 'Courier New', monospace; font-weight: normal; }
    tbody tr { border-bottom: 1px solid #f0f4fa; transition: background 0.2s; }
    tbody tr:hover { background: #f8faff; }
    tbody td { padding: 14px 20px; font-size: 13px; color: var(--navy); }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 9px; font-family: 'Courier New', monospace; letter-spacing: 1px; }
    .badge.submitted { background: #e8f5e9; color: var(--green); }
    .badge.missing   { background: #fdecea; color: var(--red); }
    .badge.flagged   { background: #fff8e1; color: #f57f17; }

    /* ── BUTTONS ── */
    .btn-report { padding: 10px 22px; background: var(--navy); color: var(--white); border: none; border-radius: 8px; font-size: 10px; letter-spacing: 2px; font-family: 'Courier New', monospace; cursor: pointer; transition: background 0.2s; }
    .btn-report:hover    { background: var(--navy-light); }
    .btn-report:disabled { background: #aab8d0; cursor: not-allowed; }

    /* ── SUBMIT FORM ── */
    .submit-card { background: var(--white); border-radius: 12px; padding: 36px; max-width: 600px; }
    .submit-card h2 { font-size: 16px; color: var(--navy); letter-spacing: 2px; font-family: 'Courier New', monospace; margin-bottom: 6px; }
    .submit-card p  { font-size: 12px; color: #aab8d0; margin-bottom: 28px; }
    .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .input-group label { display: block; font-size: 9px; letter-spacing: 2px; color: var(--navy); font-family: 'Courier New', monospace; margin-bottom: 8px; }
    .input-group input, .input-group textarea, .input-group select {
      width: 100%; padding: 12px 14px; border: 1.5px solid #dde6f5; border-radius: 8px;
      font-size: 13px; color: var(--navy); font-family: 'Georgia', serif; outline: none; transition: border 0.2s;
    }
    .input-group input:focus, .input-group textarea:focus, .input-group select:focus { border-color: var(--sky); }
    .input-group textarea { resize: vertical; min-height: 80px; }
    .submit-success { background: #e8f5e9; border-radius: 8px; padding: 16px 20px; color: var(--green); font-family: 'Courier New', monospace; font-size: 12px; letter-spacing: 1px; display: none; margin-top: 16px; }

    /* ── AI BOX ── */
    .ai-box { background: var(--navy); border-radius: 12px; padding: 28px; margin-bottom: 32px; }
    .ai-label { font-size: 9px; letter-spacing: 2.5px; color: var(--sky); font-family: 'Courier New', monospace; margin-bottom: 12px; }
    .ai-text  { font-size: 14px; color: var(--white); line-height: 1.7; }
    .ai-text span { color: var(--soft); }

    /* ── CHARTS ── */
    .chart-card { background: var(--white); border-radius: 12px; padding: 24px; margin-bottom: 32px; }
    .chart-tabs { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
    .chart-tab  { padding: 8px 16px; background: var(--soft); color: var(--navy); border: none; border-radius: 20px; font-size: 11px; font-weight: 600; font-family: 'Courier New', monospace; letter-spacing: 1px; cursor: pointer; transition: all 0.2s; }
    .chart-tab:hover  { background: var(--sky); color: var(--white); }
    .chart-tab.active { background: var(--navy); color: var(--white); }
  </style>
</head>
<body>

<!-- ══ SPLASH ══ -->
<div id="splash">
  <div id="logo-overlay">
    <svg class="splash-hex" width="80" height="92" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg" style="margin-bottom:20px;">
      <polygon points="50,5 95,28 95,87 50,110 5,87 5,28" fill="#0A2472" stroke="#4A90D9" stroke-width="2"/>
      <polygon points="50,14 85,33 85,82 50,101 15,82 15,33" fill="none" stroke="#A8D4F5" stroke-width="0.8" opacity="0.5"/>
      <polyline points="74,42 50,29 26,42 26,73 50,86 74,73" fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div class="splash-name">CIPHER</div>
  </div>
</div>

<!-- ══ LOGIN ══ -->
<div id="login" class="screen">
  <div class="login-left">
    <svg width="70" height="80" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg">
      <polygon points="50,5 95,28 95,87 50,110 5,87 5,28" fill="#0A2472" stroke="#4A90D9" stroke-width="2"/>
      <polygon points="50,14 85,33 85,82 50,101 15,82 15,33" fill="none" stroke="#A8D4F5" stroke-width="0.8" opacity="0.5"/>
      <polyline points="74,42 50,29 26,42 26,73 50,86 74,73" fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div class="brand-name">CIPHER</div>
    <div class="login-divider"></div>
    <div class="brand-tag">CENTRAL INTELLIGENCE PLATFORM<br/>FOR HOLDINGS AND EXECUTIVE REPORTING</div>
  </div>
  <div class="login-right">

    <!-- PORTAL SELECT -->
    <div id="portal-select" style="display:flex;flex-direction:column;align-items:center;width:100%;">
      <div class="login-title">Welcome to CIPHER</div>
      <div class="login-sub">SELECT YOUR PORTAL TO CONTINUE</div>
      <div style="display:flex;flex-direction:column;gap:16px;width:100%;max-width:360px;margin-top:16px;">
        <div class="portal-card" onclick="showPortal('investment')">
          <div class="portal-icon">⬡</div>
          <div><div class="portal-title">Investment Manager Portal</div><div class="portal-desc">Monitor submissions, generate reports, AI insights</div></div>
          <div class="portal-arrow">→</div>
        </div>
        <div class="portal-card" onclick="showPortal('manager')">
          <div class="portal-icon">◈</div>
          <div><div class="portal-title">Manager Portal</div><div class="portal-desc">Submit portfolio data by asset class</div></div>
          <div class="portal-arrow">→</div>
        </div>
      </div>
    </div>

    <!-- INVESTMENT MANAGER LOGIN -->
    <div id="investment-login" style="display:none;width:100%;align-items:center;flex-direction:column;">
      <div style="width:100%;max-width:360px;margin-bottom:24px;"><span class="back-btn" onclick="showPortalSelect()">← Back</span></div>
      <div class="login-title">Investment Manager Portal</div>
      <div class="login-sub">SIGN IN TO YOUR ACCOUNT</div>
      <div class="form-group"><label>EMAIL ADDRESS</label><input type="email" id="inv-email" placeholder="you@institution.com"/></div>
      <div class="form-group"><label>PASSWORD</label><input type="password" id="inv-password" placeholder="••••••••"/></div>
      <button class="btn-primary" onclick="doLogin('investment_manager')">SIGN IN</button>
      <div class="login-error" id="inv-error"></div>
      <div style="margin-top:18px;font-size:11px;color:#aab8d0;font-family:'Courier New',monospace;">No account? <span class="back-btn" onclick="toggleSignup('investment')">Sign up</span></div>
    </div>

    <!-- INVESTMENT MANAGER SIGNUP -->
    <div id="investment-signup" style="display:none;width:100%;align-items:center;flex-direction:column;">
      <div style="width:100%;max-width:360px;margin-bottom:24px;"><span class="back-btn" onclick="showPortalSelect()">← Back</span></div>
      <div class="login-title">Create Investment Manager Account</div>
      <div class="login-sub">SIGN UP TO GET STARTED</div>
      <div class="form-group"><label>FULL NAME</label><input type="text" id="invsign-name" placeholder="Jane Smith"/></div>
      <div class="form-group"><label>EMAIL ADDRESS</label><input type="email" id="invsign-email" placeholder="you@institution.com"/></div>
      <div class="form-group"><label>CONFIRM EMAIL</label><input type="email" id="invsign-email2" placeholder="you@institution.com"/></div>
      <div class="form-group"><label>PASSWORD</label><input type="password" id="invsign-password" placeholder="••••••••"/></div>
      <div class="form-group"><label>CONFIRM PASSWORD</label><input type="password" id="invsign-password2" placeholder="••••••••"/></div>
      <div class="form-group"><label>JOB TITLE</label><input type="text" id="invsign-title" placeholder="Investment Operations Director"/></div>
      <div class="form-group"><label>PHONE NUMBER</label><input type="tel" id="invsign-phone" placeholder="(555) 123-4567"/></div>
      <div class="form-group"><label>INSTITUTION NAME</label><input type="text" id="invsign-institution" placeholder="Children's Health System"/></div>
      <div class="form-group"><label>INSTITUTION LOCATION</label><input type="text" id="invsign-location" placeholder="Dallas, TX"/></div>
      <div class="form-group">
        <label>EMPLOYER IDENTIFICATION NUMBER (EIN)</label>
        <input type="text" id="invsign-ein" placeholder="12-3456789" maxlength="10"/>
        <div class="form-hint">9-digit federal tax ID for your institution.</div>
      </div>
      <div class="form-group">
        <label>WORK EMAIL DOMAIN</label>
        <input type="text" id="invsign-domain" placeholder="childrens.org"/>
        <div class="form-hint">Must match your email address domain for verification.</div>
      </div>
      <button class="btn-primary" onclick="doSignup('investment_manager')">CREATE ACCOUNT</button>
      <div class="login-error" id="invsign-error"></div>
      <div style="margin-top:18px;font-size:11px;color:#aab8d0;font-family:'Courier New',monospace;">Already have an account? <span class="back-btn" onclick="toggleLogin('investment')">Sign in</span></div>
    </div>

    <!-- MANAGER LOGIN -->
    <div id="manager-login" style="display:none;width:100%;align-items:center;flex-direction:column;">
      <div style="width:100%;max-width:360px;margin-bottom:24px;"><span class="back-btn" onclick="showPortalSelect()">← Back</span></div>
      <div class="login-title">Manager Portal</div>
      <div class="login-sub">SIGN IN TO YOUR ACCOUNT</div>
      <div class="form-group"><label>EMAIL ADDRESS</label><input type="email" id="mgr-email" placeholder="you@institution.com"/></div>
      <div class="form-group"><label>PASSWORD</label><input type="password" id="mgr-password" placeholder="••••••••"/></div>
      <button class="btn-primary" onclick="doLogin('manager')">SIGN IN</button>
      <div class="login-error" id="mgr-error"></div>
      <div style="margin-top:18px;font-size:11px;color:#aab8d0;font-family:'Courier New',monospace;">No account? <span class="back-btn" onclick="toggleSignup('manager')">Sign up</span></div>
    </div>

    <!-- MANAGER SIGNUP -->
    <div id="manager-signup" style="display:none;width:100%;align-items:center;flex-direction:column;">
      <div style="width:100%;max-width:360px;margin-bottom:24px;"><span class="back-btn" onclick="showPortalSelect()">← Back</span></div>
      <div class="login-title">Create Manager Account</div>
      <div class="login-sub">SIGN UP TO GET STARTED</div>
      <div class="form-group"><label>FULL NAME</label><input type="text" id="mgrsign-name" placeholder="John Doe"/></div>
      <div class="form-group"><label>EMAIL ADDRESS</label><input type="email" id="mgrsign-email" placeholder="you@institution.com"/></div>
      <div class="form-group"><label>CONFIRM EMAIL</label><input type="email" id="mgrsign-email2" placeholder="you@institution.com"/></div>
      <div class="form-group"><label>PASSWORD</label><input type="password" id="mgrsign-password" placeholder="••••••••"/></div>
      <div class="form-group"><label>CONFIRM PASSWORD</label><input type="password" id="mgrsign-password2" placeholder="••••••••"/></div>
      <div class="form-group"><label>INSTITUTION NAME</label><input type="text" id="mgrsign-institution" placeholder="Children's Health System"/></div>
      <div class="form-group">
        <label>EMPLOYER IDENTIFICATION NUMBER (EIN)</label>
        <input type="text" id="mgrsign-ein" placeholder="12-3456789" maxlength="10"/>
        <div class="form-hint">9-digit federal tax ID for your institution.</div>
      </div>
      <div class="form-group">
        <label>WORK EMAIL DOMAIN</label>
        <input type="text" id="mgrsign-domain" placeholder="childrens.org"/>
        <div class="form-hint">Must match your email address domain for verification.</div>
      </div>
      <div class="form-group">
        <label>ASSET CLASS</label>
        <select id="mgrsign-asset">
          <option value="">Select your asset class</option>
          <option>Public Equity</option>
          <option>Private Equity</option>
          <option>Operations</option>
          <option>Fixed Income</option>
          <option>Real Assets</option>
          <option>Other</option>
        </select>
      </div>
      <button class="btn-primary" onclick="doSignup('manager')">CREATE ACCOUNT</button>
      <div class="login-error" id="mgrsign-error"></div>
      <div style="margin-top:18px;font-size:11px;color:#aab8d0;font-family:'Courier New',monospace;">Already have an account? <span class="back-btn" onclick="toggleLogin('manager')">Sign in</span></div>
    </div>

  </div>
</div>

<!-- ══ 2FA SCREEN ══ -->
<div id="twofa" class="screen">
  <div class="login-left">
    <svg width="70" height="80" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg">
      <polygon points="50,5 95,28 95,87 50,110 5,87 5,28" fill="#0A2472" stroke="#4A90D9" stroke-width="2"/>
      <polygon points="50,14 85,33 85,82 50,101 15,82 15,33" fill="none" stroke="#A8D4F5" stroke-width="0.8" opacity="0.5"/>
      <polyline points="74,42 50,29 26,42 26,73 50,86 74,73" fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div class="brand-name">CIPHER</div>
    <div class="login-divider"></div>
    <div class="brand-tag">TWO-FACTOR AUTHENTICATION</div>
  </div>
  <div class="login-right">
    <div style="width:100%;max-width:360px;display:flex;flex-direction:column;align-items:center;">
      <div class="login-title">Verify Your Identity</div>
      <div class="login-sub">ENTER THE 6-DIGIT CODE</div>
      <div id="twofa-hint" style="font-size:12px;color:#aab8d0;font-family:'Courier New',monospace;margin-bottom:24px;text-align:center;line-height:1.6;">
        A verification code has been generated. Check your browser console (press F12) while in testing mode.
      </div>
      <div class="form-group">
        <label>VERIFICATION CODE</label>
        <input type="text" id="twofa-code" placeholder="000000" maxlength="6"
          style="letter-spacing:8px;font-size:22px;text-align:center;"
          oninput="this.value=this.value.replace(/[^0-9]/g,'')"/>
      </div>
      <button class="btn-primary" onclick="verifyTwoFA()">VERIFY & SIGN IN</button>
      <div class="login-error" id="twofa-error"></div>
      <div style="margin-top:18px;font-size:11px;color:#aab8d0;font-family:'Courier New',monospace;text-align:center;">
        Didn't get a code? <span class="back-btn" onclick="resendCode()">Resend</span>
        &nbsp;·&nbsp;
        <span class="back-btn" onclick="show('login');showPortalSelect();currentUser=null;pendingUser=null;">Cancel</span>
      </div>
    </div>
  </div>
</div>

<!-- ══ DIRECTOR DASHBOARD ══ -->
<div id="director-dash" class="screen">
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-brand">CIPHER</div>
      <div class="sidebar-role">DIRECTOR PORTAL</div>
    </div>
    <div class="nav-section-label">OVERVIEW</div>
    <div class="nav-item active" onclick="dirTab(this,'dir-overview')"><span class="nav-dot"></span>Dashboard</div>
    <div class="nav-item" onclick="dirTab(this,'dir-submissions')"><span class="nav-dot"></span>Submissions</div>
    <div class="nav-section-label">ANALYTICS</div>
    <div class="nav-item" onclick="dirTab(this,'dir-analytics')"><span class="nav-dot"></span>Portfolio Analytics</div>
    <div class="nav-item" onclick="dirTab(this,'dir-exposure')"><span class="nav-dot"></span>Exposure Analysis</div>
    <div class="nav-item" onclick="dirTab(this,'dir-liquidity')"><span class="nav-dot"></span>Liquidity</div>
    <div class="nav-item" onclick="dirTab(this,'dir-private')"><span class="nav-dot"></span>Private Markets</div>
    <div class="nav-section-label">INTELLIGENCE</div>
    <div class="nav-item" onclick="dirTab(this,'dir-ai')"><span class="nav-dot"></span>AI Insights</div>
